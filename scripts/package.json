{
  "name": "@workspace/scripts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "hello": "tsx ./src/hello.ts",
    "seed": "tsx ./src/seed.ts",
    "import": "tsx ./src/import.ts",
    "crawl": "tsx ./src/crawl.ts",
    "discover": "tsx ./src/crawl.ts --discover",
    "export:payload": "tsx ./src/export-payload.ts",
    "import:payload": "tsx ./src/import-payload.ts",
