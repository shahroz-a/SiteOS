{
  "name": "@workspace/scripts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "hello": "tsx ./src/hello.ts",
    "seed": "tsx ./src/seed.ts",
    "import": "tsx ./src/import.ts",
    "crawl": "tsx ./src/crawl.ts",
    "revalidate": "tsx ./src/revalidate.ts",
    "reextract": "tsx ./src/reextract.ts",
    "discover": "tsx ./src/crawl.ts --discover",
    "export:payload": "tsx ./src/export-payload.ts",
    "import:payload": "tsx ./src/import-payload.ts",
    "load:payload": "tsx ./src/load-payload.ts",
    "migrate:payload": "tsx ./src/migrate-payload.ts",
    "prerender:blog": "tsx ./src/prerender-blog.ts",
    "redirect:health": "tsx ./src/redirect-health.ts",
    "views:rollup": "tsx ./src/rollup-page-views.ts",
    "build:jobs": "node ./build.mjs",
    "redirect:health:prod": "node ./dist/redirect-health.mjs",
    "views:rollup:prod": "node ./dist/rollup-page-views.mjs",
    "categories:backfill": "tsx ./src/derive-categories.ts",
    "cleanup:redirects": "tsx ./src/cleanup-redirects.ts",
    "verify:redirect-targets": "tsx ./src/check-redirect-targets.ts",
    "reclassify:non-blog": "tsx ./src/reclassify-non-blog-pages.ts",
    "ensure:search-indexes": "tsx ./src/ensure-search-indexes.ts",
    "ensure:analytics": "tsx ./src/ensure-analytics.ts",
    "test": "vitest run",
    "verify:roundtrip": "cd .. && VERIFY_REAL_DATA=1 vitest run scripts/src/payload/__tests__/roundtrip-real-data.test.ts",
    "verify:redirects": "cd .. && VERIFY_REAL_DATA=1 vitest run scripts/src/prerender/__tests__/redirect-stubs-real-data.test.ts",
    "verify:redirect-health": "cd .. && VERIFY_REAL_DATA=1 vitest run scripts/src/prerender/__tests__/redirect-health-real-data.test.ts",
    "verify:rollup": "cd .. && VERIFY_REAL_DATA=1 vitest run scripts/src/__tests__/rollup-page-views-real-data.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@workspace/blog-seo": "workspace:*",
    "@workspace/content": "workspace:*",
    "@workspace/content-validation": "workspace:*",
    "@workspace/db": "workspace:*",
    "cheerio": "^1.2.0",
    "domhandler": "^6.0.1",
    "drizzle-orm": "catalog:",
    "fast-xml-parser": "^5.9.2",
    "nodemailer": "^9.0.1",
    "playwright": "^1.61.0"
  },
  "devDependencies": {
    "@payloadcms/db-sqlite": "^3.85.1",
    "@types/node": "catalog:",
    "esbuild": "0.27.3",
    "graphql": "^16.14.2",
    "payload": "^3.85.1",
    "tsx": "catalog:"
  }
}
