modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Blog Crawl"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "verify-cms-io"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "cms-e2e"

[[workflows.workflow]]
name = "test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run test"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "Blog Crawl"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run crawl -- --crawl --no-browser --concurrency=8"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "verify-cms-io"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run verify:cms-io"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run typecheck:libs && pnpm --filter @workspace/api-server --filter @workspace/cms --filter @workspace/blog run typecheck"

[[workflows.workflow]]
name = "cms-e2e"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/cms run test:e2e"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 8083
externalPort = 3001

[[ports]]
localPort = 8099
externalPort = 8099

[[ports]]
localPort = 23396
externalPort = 3003

[[ports]]
localPort = 23397
externalPort = 5000

[[ports]]
localPort = 23740
externalPort = 3002

[[ports]]
localPort = 25729
externalPort = 3000

[nix]
channel = "stable-25_05"
