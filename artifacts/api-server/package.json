{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs && pnpm --filter @workspace/scripts run build:jobs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "verify:media": "cd ../.. && VERIFY_REAL_DATA=1 vitest run artifacts/api-server/src/lib/__tests__/media-real-data.test.ts",
    "verify:media-audit": "cd ../.. && VERIFY_REAL_DATA=1 vitest run artifacts/api-server/src/routes/__tests__/cms-media-audit-real-data.test.ts",
    "verify:publish-scheduled": "cd ../.. && VERIFY_REAL_DATA=1 vitest run artifacts/api-server/src/lib/__tests__/publish-scheduled-real-data.test.ts",
    "verify:analytics-maintenance": "cd ../.. && VERIFY_REAL_DATA=1 vitest run artifacts/api-server/src/lib/__tests__/analytics-maintenance-real-data.test.ts",
    "verify:analytics-views": "cd ../.. && VERIFY_REAL_DATA=1 vitest run artifacts/api-server/src/lib/__tests__/analytics-views-real-data.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seo:reports": "tsx ./src/lib/generate-seo-reports.ts",
    "verify:cms-io": "cd ../.. && VERIFY_CMS_IO=1 CMS_IO_VERIFY_LIMIT=3 vitest run artifacts/api-server/src/lib/__tests__/cms-io.integration.test.ts",
    "verify:cms-io:full": "cd ../.. && VERIFY_CMS_IO=1 vitest run artifacts/api-server/src/lib/__tests__/cms-io.integration.test.ts",
    "verify:cms-write": "cd ../.. && VERIFY_CMS_WRITE=1 vitest run artifacts/api-server/src/lib/__tests__/cms-publishing.integration.test.ts artifacts/api-server/src/lib/__tests__/cms-publishing-route.integration.test.ts"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.21.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/article-parser": "workspace:*",
    "@workspace/cms-auth": "workspace:*",
    "@workspace/content": "workspace:*",
    "@workspace/content-io": "workspace:*",
    "@workspace/content-validation": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-openai-ai-server": "workspace:*",
    "@workspace/seo-validation": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "google-auth-library": "^10.7.0",
    "openid-client": "^6.8.4",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
